
<div class="characters-container">
    <section class="char-gallery-section">
        <div class="char-page-head">
            <h1><%= t('characters.gallery_title') %></h1>
        </div>
        <mdui-text-field id="char-gallery-search" label="<%= t('characters.search_placeholder') %>" icon="search" clearable variant="outlined"></mdui-text-field>

        <div class="char-gallery-grid">
            <% if (!cards || cards.length === 0) { %>
                <div class="char-empty-block">
                    <mdui-icon name="person_off"></mdui-icon>
                    <p><%= t('characters.no_cards_hint') %></p>
                </div>
            <% } else { %>
                <% cards.forEach((card) => { %>
                    <div class="char-item-card mdui-ripple <%= selectedFile === card.fileName ? 'active' : '' %>" data-edit-character="<%= encodeURIComponent(card.fileName) %>" style="cursor: pointer;">
                        <div class="char-card-image">
                            <% if (card.hasAvatar && card.avatarUrl) { %>
                                <img class="char-card-image-el" src="<%= card.avatarUrl %>" alt="<%= card.displayName %>">
                            <% } else { %>
                                <mdui-icon name="person"></mdui-icon>
                            <% } %>
                            <div class="char-card-actions">
                                <mdui-button-icon
                                    icon="delete"
                                    class="delete-card-btn"
                                    data-filename="<%= card.fileName %>"
                                    data-displayname="<%= card.displayName %>"
                                ></mdui-button-icon>
                            </div>
                        </div>
                        <div class="char-card-info">
                            <h3 class="char-card-name"><%= card.displayName %></h3>
                            <div class="char-card-meta">
                                <% if (card.worldBook) { %>
                                    <span class="char-card-badge wb">
                                        <mdui-icon name="menu_book" style="font-size: 12px;"></mdui-icon>
                                        <%= card.worldBook.replace('.json', '') %>
                                    </span>
                                <% } %>
                                <span class="char-card-badge"><%= (card.size / 1024).toFixed(1) %> KB</span>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } %>
        </div>
    </section>

    <mdui-dialog id="char-editor-modal" close-on-esc close-on-overlay-click>
        <div class="char-editor-card">
            <div class="char-editor-header">
                <div class="char-editor-avatar">
                    <img class="char-editor-avatar-el" id="modal-char-avatar" src="" alt="Avatar" style="display: none; width: 64px; height: 64px; border-radius: 16px; object-fit: cover; box-shadow: var(--mdui-elevation-level-1);">
                    <mdui-icon id="modal-char-avatar-placeholder" name="person" style="font-size: 56px; opacity: 0.3;"></mdui-icon>
                </div>
                <div class="char-editor-title-box" style="flex: 1;">
                    <h2 id="modal-char-name-display" style="margin: 0; font-size: 24px; font-weight: 700;">Name</h2>
                    <p id="modal-char-filename-display" style="margin: 4px 0 0; font-size: 14px; color: rgb(var(--mdui-color-on-surface-variant));">filename.json</p>
                </div>
                <mdui-button-icon icon="close" id="close-char-editor-btn" variant="standard" style="align-self: flex-start; margin: -12px -12px 0 0;"></mdui-button-icon>
            </div>

            <form id="modal-char-editor-form" autocomplete="off" style="display: flex; flex-direction: column; flex: 1; overflow: hidden; background: rgb(var(--mdui-color-surface));">
                <input type="hidden" name="fileName" id="modal-char-filename">
                <input type="hidden" name="embeddedLoreJson" id="modal-embedded-lore-json">
                <input type="hidden" name="worldBook" id="modal-char-worldbook-hidden">
                
                <mdui-tabs value="char-basic" class="char-editor-tabs" placement="top" style="flex: 1; min-height: 0;">
                    <mdui-tab value="char-basic" icon="person_outline"><%= t('characters.tab_basic') %></mdui-tab>
                    <mdui-tab value="char-story" icon="history_edu"><%= t('characters.tab_opening') %></mdui-tab>
                    <mdui-tab value="char-advanced" icon="tune"><%= t('characters.tab_advanced') %></mdui-tab>
                    <mdui-tab value="char-lore" icon="auto_stories"><%= t('characters.tab_lore') %></mdui-tab>

                    <mdui-tab-panel value="char-basic" slot="panel" class="char-tab-panel" style="overflow-y: auto;">
                        <div class="char-form-grid">
                            <mdui-text-field name="cardName" id="modal-input-cardName" label="<%= t('characters.label_card_name') %>" required variant="outlined"></mdui-text-field>
                            <mdui-text-field name="description" id="modal-input-description" label="<%= t('characters.label_description') %>" rows="8" autosize variant="outlined"></mdui-text-field>
                        </div>
                    </mdui-tab-panel>

                    <mdui-tab-panel value="char-story" slot="panel" class="char-tab-panel" style="overflow-y: auto;">
                        <div class="char-form-grid two-cols">
                            <mdui-text-field name="firstMessage" id="modal-input-firstMessage" label="<%= t('characters.label_first_message') %>" rows="7" autosize variant="outlined"></mdui-text-field>
                            <mdui-text-field name="alternateGreetings" id="modal-input-alternateGreetings" label="<%= t('characters.label_alternate_greetings') %>" rows="7" autosize variant="outlined"></mdui-text-field>
                            <mdui-text-field name="scenario" id="modal-input-scenario" label="<%= t('characters.label_scenario') %>" rows="6" autosize variant="outlined"></mdui-text-field>
                            <mdui-text-field name="personality" id="modal-input-personality" label="<%= t('characters.label_personality') %>" rows="6" autosize variant="outlined"></mdui-text-field>
                            <mdui-text-field name="messageExample" id="modal-input-messageExample" label="<%= t('characters.label_message_example') %>" rows="10" autosize variant="outlined" style="grid-column: 1 / -1;"></mdui-text-field>
                        </div>
                    </mdui-tab-panel>

                    <mdui-tab-panel value="char-advanced" slot="panel" class="char-tab-panel" style="overflow-y: auto;">
                        <div class="char-form-grid">
                            <mdui-text-field name="systemPrompt" id="modal-input-systemPrompt" label="<%= t('characters.label_system_prompt') %>" rows="6" autosize variant="outlined"></mdui-text-field>
                            <mdui-text-field name="postHistoryInstructions" id="modal-input-postHistoryInstructions" label="<%= t('characters.label_post_history') %>" rows="4" autosize variant="outlined"></mdui-text-field>
                            <mdui-text-field name="creatorNotes" id="modal-input-creatorNotes" label="<%= t('characters.creator_note') %>" rows="4" autosize variant="outlined"></mdui-text-field>
                            <mdui-text-field name="tags" id="modal-input-tags" label="<%= t('characters.tags_comma') %>" variant="outlined"></mdui-text-field>
                        </div>
                    </mdui-tab-panel>

                    <mdui-tab-panel value="char-lore" slot="panel" class="char-tab-panel">
                        <div style="position: sticky; top: -24px; z-index: 10; margin-bottom: 16px; background: rgb(var(--mdui-color-surface)); padding: 12px 0; margin-top: -24px; padding-top: 24px;">
                            <div>
                                <h3 style="margin: 0;"><%= t('characters.linked_world_book') %></h3>
                                <p style="margin: 4px 0 0; color: rgb(var(--mdui-color-on-surface-variant)); font-size: 13px;"><%= t('characters.linked_world_book_desc') %></p>
                            </div>
                        </div>
                        <div style="display: flex; flex-direction: column; gap: 16px;">
                            <mdui-select id="modal-char-worldbook" label="<%= t('room.world_book_label') %>" variant="outlined" full-width>
                                <mdui-menu-item value=""><%= t('characters.linked_world_book_none') %></mdui-menu-item>
                                <% worldBooks.forEach(wb => { %>
                                    <mdui-menu-item value="<%= wb.fileName %>"><%= wb.displayName %> (<%= wb.fileName %>)</mdui-menu-item>
                                <% }) %>
                            </mdui-select>
                        </div>
                    </mdui-tab-panel>
                </mdui-tabs>

                <div class="char-editor-actions" style="flex-shrink: 0; background: rgb(var(--mdui-color-surface)); z-index: 1;">
                    <mdui-button type="submit" variant="filled" icon="save" id="modal-save-btn" size="large"><%= t('characters.save_changes') %></mdui-button>
                </div>
            </form>
        </div>
    </mdui-dialog>

    <div class="char-fab-group">
        <mdui-fab id="import-character-file-trigger" icon="upload" variant="secondary" extended><%= t('characters.import_character') %></mdui-fab>
        <mdui-fab id="open-create-character-dialog" icon="add" variant="primary" extended><%= t('characters.new_character') %></mdui-fab>
    </div>

    <form id="character-file-import-form" method="post" action="/characters/import-file" enctype="multipart/form-data" style="display:none;" autocomplete="off">
        <input id="character-file-input" name="cardFile" type="file" accept=".json,.png">
    </form>

    <mdui-dialog id="create-character-dialog">
        <span slot="headline"><%= t('characters.dialog_create_title') %></span>
        <form id="create-character-form" method="post" action="/characters/create" style="display: flex; flex-direction: column; gap: 20px; margin-top: 12px;" autocomplete="off">
            <mdui-text-field name="cardName" label="<%= t('characters.label_card_name') %>" required variant="outlined"></mdui-text-field>
            <mdui-text-field name="description" label="<%= t('characters.label_description_short') %>" rows="3" autosize variant="outlined"></mdui-text-field>
        </form>
        <div slot="action">
            <mdui-button variant="text" onclick="this.closest('mdui-dialog').open = false;"><%= t('common.cancel') %></mdui-button>
            <mdui-button type="submit" form="create-character-form" variant="filled"><%= t('characters.create_now') %></mdui-button>
        </div>
    </mdui-dialog>

    <mdui-dialog id="delete-character-confirm-dialog" class="persona-dialog" close-on-overlay-click close-on-esc style="--mdui-dialog-width: 480px;">
        <div slot="headline" class="dialog-header-clean">
            <div>
                <h2 class="dialog-headline" style="margin:0;"><%= t('characters.confirm_delete') %></h2>
            </div>
            <mdui-button-icon class="dialog-close-btn" icon="close" onclick="this.closest('mdui-dialog').open = false"></mdui-button-icon>
        </div>
        <p id="delete-character-confirm-text" style="padding: 8px 32px 24px; margin:0;"><%= t('characters.confirm_delete_msg') %></p>
        <form id="delete-character-form" method="post" action="/characters/delete" autocomplete="off" style="display:none;">
            <input type="hidden" name="fileName" id="delete-character-filename">
        </form>
        <div slot="action">
            <mdui-button variant="text" onclick="this.closest('mdui-dialog').open = false;" style="border-radius:12px;"><%= t('common.cancel') %></mdui-button>
            <mdui-button type="submit" form="delete-character-form" variant="tonal" icon="delete" style="border-radius:12px;color:rgb(var(--mdui-color-error));"><%= t('common.delete_confirm') %></mdui-button>
        </div>
    </mdui-dialog>
</div>
