<div class="worldbooks-page" <% if (error) { %>data-error="<%= error %>"<% } %> <% if (success) { %>data-success="<%= success %>"<% } %>>
    <section class="mdui-card hero-card" style="overflow: hidden; position: relative;">
        <div class="hero-content" style="position: relative; z-index: 2;">
            <h2 class="user-greeting"><%= t('sessions.page_heading') %></h2>
        </div>
    </section>

    <div class="mdui-container-fluid" style="margin-top: 24px; padding: 0 4px;">
        <% if (!sessions || sessions.length === 0) { %>
            <div class="mdui-card" style="display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 80px 20px; text-align: center; opacity: 0.8; border-radius: 24px; background: transparent; border: 2px dashed rgba(var(--mdui-color-outline-variant), 0.5);">
                <mdui-icon name="history_toggle_off" style="font-size: 64px; margin-bottom: 16px; color: rgb(var(--mdui-color-primary));"></mdui-icon>
                <div class="mdui-typo-title"><%= t('sessions.empty') %></div>
                <p><%= t('sessions.empty_desc') %></p>
            </div>
        <% } else { %>
            <div class="sessions-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(360px, 1fr)); gap: 20px;">
                <% sessions.forEach((session) => { %>
                    <mdui-card class="session-card" style="border-radius: 20px; border: 1px solid rgba(var(--mdui-color-outline-variant), 0.3); transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); cursor: default; overflow: hidden;">
                        <div style="display: flex; height: 160px;">
                            <!-- Character Avatar Block -->
                            <div class="session-avatar-wrap" style="width: 120px; min-width: 120px; height: 100%; position: relative; overflow: hidden; background: rgb(var(--mdui-color-surface-container-highest));">
                                <img src="/api/characters/avatar/<%= encodeURIComponent(session.characterFile) %>" 
                                     style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease;"
                                     onerror="this.src='data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 24 24%22 fill=%22%23ccc%22><path d=%22M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z%22/></svg>'">
                            </div>
                            
                            <!-- Session Info Block -->
                            <div style="flex: 1; padding: 16px; display: flex; flex-direction: column; justify-content: space-between; overflow: hidden;">
                                <div style="overflow: hidden;">
                                    <div class="mdui-typo-title" style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis; font-size: 1.15rem; margin-bottom: 2px;" title="<%= session.name %>">
                                        <%= session.name %>
                                    </div>
                                    <div style="font-size: 0.85rem; opacity: 0.6; margin-bottom: 8px;">ROOMID: <%= session.id %></div>
                                    
                                    <div style="font-size: 0.9rem; display: flex; align-items: center; gap: 6px; margin-bottom: 4px;">
                                        <mdui-icon name="person_outline" style="font-size: 1.1rem; opacity: 0.8;"></mdui-icon>
                                        <span style="opacity: 0.9;"><%= session.characterName %></span>
                                    </div>
                                    <div style="font-size: 0.9rem; display: flex; align-items: center; gap: 6px;">
                                        <mdui-icon name="history" style="font-size: 1.1rem; opacity: 0.8;"></mdui-icon>
                                        <span style="opacity: 0.7;"><%= session.lastDialogueAtText %></span>
                                    </div>
                                </div>
                                
                                <!-- Card Actions -->
                                <div style="display: flex; align-items: center; justify-content: flex-end; gap: 4px; margin-top: 12px; border-top: 1px solid rgba(var(--mdui-color-outline-variant), 0.3); padding-top: 12px;">
                                    <form class="delete-session-form" method="post" action="/sessions/delete">
                                        <input type="hidden" name="sessionId" value="<%= session.id %>">
                                        <mdui-button-icon class="delete-session-btn" icon="delete_outline" title="<%= t('sessions.delete_record') %>" style="color: rgb(var(--mdui-color-error));"></mdui-button-icon>
                                    </form>
                                    <div style="flex: 1;"></div>
                                    <form method="post" action="/rooms/create">
                                        <input type="hidden" name="mode" value="continue">
                                        <input type="hidden" name="sessionId" value="<%= session.id %>">
                                        <input type="hidden" name="roomTitle" value="<%= session.name %>">
                                        <mdui-button type="submit" variant="tonal" end-icon="arrow_forward" style="border-radius: 12px;"><%= t('sessions.continue_adventure') %></mdui-button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </mdui-card>
                <% }) %>
            </div>
        <% } %>
    </div>
</div>

<style>
.session-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 24px rgba(0,0,0,0.12);
    border-color: rgb(var(--mdui-color-primary) / 0.5) !important;
}
.session-card:hover .session-avatar-wrap img {
    transform: scale(1.1);
}
@media (max-width: 600px) {
    .sessions-grid {
        grid-template-columns: 1fr !important;
    }
}
</style>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        document.querySelectorAll('.delete-session-btn').forEach(btn => {
            btn.addEventListener('click', (e) => {
                e.preventDefault();
                if (confirm('<%= t('sessions.delete_confirm_inline') %>')) {
                    btn.closest('form').submit();
                }
            });
        });
    });
</script>
